@model examenInsertEF7.ViewModel.EmpleadoVM

@{
    ViewData["Title"] = "Gestión de Empleados";
}

<div class="container">
    <div class="m-2 card">
        <form asp-action="Guardar" method="post">
            <div class="card-header">
                <h2>Form Empleado</h2>
            </div>
            <div class="card-body">
                <div class="m-2">
                    <label>Nombre Empleado: </label>
                    <input asp-for="EmpleadoModelReference.NombreEmpleado" required />
                </div>
                <div class="m-2">
                    <label>Departamento: </label>
                    <select asp-for="EmpleadoModelReference.IdDepartamento"
                            asp-items="@(new SelectList(Model.ListaDepartamentos, "IdDepartamento", "NombreDepartamento"))" required>
                        <option value="">--Selecciona un Departamento--</option>
                    </select>
                </div>
                <div>
                    <button type="submit" class="m-2 btn btn-secondary">
                        Guardar
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="m-1 card">
        <div class="m-2">
            <div class="m-2 card-header">
                <h2>Filtro Por Departamento: </h2>
            </div>
            <select onchange="location.href='?idDep=' + this.value">
                <option value="0">--Ver Todos--</option>
                @foreach (var dep in Model.ListaDepartamentos)
                {
                    <option value="@dep.IdDepartamento" selected="@(dep.IdDepartamento == ViewBag.IdSeleccionado)">
                        @dep.NombreDepartamento
                    </option>
                }
            </select>
        </div>
        <div class="m-2">
            <a asp-action="Index" class="btn btn-primary">Limpiar</a>
        </div>
    </div>

    <div class="m-2">
        <table class="table table-striped table-hover border">
            @* Agregué bordes y efectos *@
            <thead class="table-dark">
                @* <-- Aquí el cambio clave *@
                <tr>
                    <th scope="col">IdEmpleado</th>
                    <th scope="col">NombreEmpleado</th>
                    <th scope="col">Departamento</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ListaEmpleados == null || !Model.ListaEmpleados.Any())
                {
                    <tr>
                        @* Usamos colspan="3" para que ocupe todo el ancho *@
                        <td colspan="3" class="text-center text-muted">
                            No se encontró usuario con los requerimientos especificados
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var emp in Model.ListaEmpleados)
                    {
                        <tr>
                            <th scope="row">@emp.IdEmpleado</th>
                            <td>@emp.NombreEmpleado</td>
                            <td>@emp.IdDepartamentoNavigation?.NombreDepartamento</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
